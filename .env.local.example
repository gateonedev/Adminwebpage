# Copy to .env.local and fill in. Same Supabase project as the mobile app.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_. Used by
# server actions to create / delete / reset-password admin accounts via
# the Supabase Admin API. If this leaks to the browser, rotate it.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
